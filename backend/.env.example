ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin

PORT=5000
NODE_ENV=production

MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/eford

JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars

CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_key
CLOUDFLARE_R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET_NAME=eford-files
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your_smtp_api_key
EMAIL_FROM=noreply@ecole.fr

FRONTEND_URL=https://mon-ecole.pages.dev
